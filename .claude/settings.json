{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [],
    "SubagentStop": [],
    "Stop": [],
    "Notification": [],
    "UserPromptSubmit": [],
    "SessionEnd": []
  },
  "model": "opus",
  "alwaysThinkingEnabled": true,
  "disableAllHooks": false,
  "enableAllProjectMcpServers": true
}
